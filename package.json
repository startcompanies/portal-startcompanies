{
  "name": "portal-startcompanies",
  "version": "1.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build --configuration production --output-hashing=all",
    "build:dev": "ng build --configuration development",
    "build:ssr": "ng build --output-hashing=all && ng run portal-startcompanies:server",
    "serve:ssr": "node dist/portal-startcompanies/server/main.js",
    "dev:ssr": "npm run build:ssr && npm run serve:ssr",
    "clean": "rm -rf dist && npm cache clean --force",
    "build:production": "ng build --configuration production --output-hashing=all && ng run portal-startcompanies:server:production",
    "build:staging": "ng build --configuration staging --output-hashing=all && ng run portal-startcompanies:server:staging",
    "docker:build": "npm run build:production && docker build -t portal-startcompanies .",
    "docker:build:staging": "npm run build:staging && docker build --build-arg BUILD_CONFIGURATION=staging --build-arg NODE_ENV=production -t portal-startcompanies:staging ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/cdk": "^18.2.14",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/material": "^18.2.14",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/platform-server": "^18.2.14",
    "@angular/router": "^18.2.14",
    "@angular/service-worker": "^18.2.14",
    "@angular/ssr": "^18.2.14",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@jsverse/transloco": "^7.6.1",
    "@jsverse/transloco-persist-lang": "8.0.0",
    "@jsverse/utils": "1.0.0-beta.5",
    "@ngneat/transloco": "^6.0.4",
    "@popperjs/core": "^2.11.8",
    "@stripe/stripe-js": "^8.6.0",
    "@types/bootstrap": "^5.2.10",
    "@types/youtube": "^0.0.50",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "express": "^4.18.2",
    "intl-tel-input": "^25.14.1",
    "ngx-youtube-player": "^18.0.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.14",
    "@angular/cli": "^18.2.14",
    "@angular/compiler-cli": "^18.2.14",
    "@types/express": "^4.17.17",
    "@types/intl-tel-input": "^18.1.4",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "sharp": "^0.34.3",
    "terser": "^5.43.1",
    "typescript": "~5.5.2"
  }
}
